// =============================================================
// Relay — Database Schema
//
// Defines the PostgreSQL data model for relays (servers), users,
// and per-relay configuration settings.
// =============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum ReminderStatus {
  PENDING
  DELIVERED
  CANCELLED
  FAILED
}

enum RuleType {
  BANNED_PHRASE
  REGEX
}

enum RuleAction {
  DELETE
  WARN
  MUTE
}

enum ModerationActionType {
  WARN
  KICK
  BAN
  MUTE
}

// --- Relay ---
// Represents a Discord server registered with Relay.
model Relay {
  id        String        @id
  name      String
  prefix    String        @default("!")
  language  String        @default("en")
  settings  RelaySetting?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  reminders        Reminder[]
  moderationRules  ModerationRule[]
  moderationActions ModerationAction[]

  @@map("relays")
}

// --- User ---
// A Discord user that has interacted with the bot.
model User {
  id            String   @id
  username      String
  discriminator String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reminders          Reminder[]
  moderationActions  ModerationAction[]  @relation("ModeratedUser")
  moderatorActions   ModerationAction[]  @relation("Moderator")

  @@map("users")
}

// --- Relay Settings ---
// Per-relay configuration: welcome messages, mod logs, etc.
model RelaySetting {
  id               String @id @default(cuid())
  welcomeMessage   String @default("")
  modLogChannelId  String @default("")
  welcomeChannelId String @default("")

  relayId   String   @unique
  relay     Relay    @relation(fields: [relayId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("relay_settings")
}

// --- Reminder ---
// A scheduled reminder created by a user.
model Reminder {
  id        String         @id @default(cuid())
  message   String
  dueAt     DateTime
  channelId String
  status    ReminderStatus @default(PENDING)
  retries   Int            @default(0)

  userId    String
  user      User           @relation(fields: [userId], references: [id])
  relayId   String
  relay     Relay          @relation(fields: [relayId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([status, dueAt])
  @@map("reminders")
}

// --- Moderation Rule ---
// An auto-moderation rule for a relay (e.g. banned phrases).
model ModerationRule {
  id       String     @id @default(cuid())
  type     RuleType
  pattern  String
  action   RuleAction @default(DELETE)
  enabled  Boolean    @default(true)

  relayId   String
  relay     Relay    @relation(fields: [relayId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([relayId, enabled])
  @@map("moderation_rules")
}

// --- Moderation Action ---
// A log entry for a moderation action taken on a user.
model ModerationAction {
  id       String               @id @default(cuid())
  action   ModerationActionType
  reason   String
  duration Int?                 // minutes, for MUTE actions

  userId      String
  user        User     @relation("ModeratedUser", fields: [userId], references: [id])
  moderatorId String
  moderator   User     @relation("Moderator", fields: [moderatorId], references: [id])
  relayId     String
  relay       Relay    @relation(fields: [relayId], references: [id])
  createdAt   DateTime @default(now())

  @@index([relayId, userId])
  @@map("moderation_actions")
}
