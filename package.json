    "db:studio": "prisma studio"
  },
  "engines": {
    "node": ">=22.22.0 <25",
    "npm": ">=10 <11"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.1",
    "fastify": "^5.8.4",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
